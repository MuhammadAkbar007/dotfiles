{
	"group/quicksettings": {
		"orientation": "horizontal",
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-memory",
			"transition-left-to-right": false
		},
		"modules": [ // The first element is the "anchor" (always visible)
			"network",
			"cpu",
			"memory",
			"pulseaudio",
			"backlight",
			"privacy",
			"custom/notification",
			"custom/nightlight",
			"idle_inhibitor",
			"custom/power"
		]
	}
}
