# exec_always --no-startup-id feh --bg-fill /home/akbar/Pictures/desktop_wallpapers/dark/treeBreeze.jpg
# exec_always --no-startup-id feh --bg-fill /home/akbar/Pictures/desktop_wallpapers/dark/hyundai.jpg
# exec_always --no-startup-id feh --bg-fill /home/akbar/Pictures/desktop_wallpapers/dark/ready_player_one.jpg
exec_always --no-startup-id feh --bg-fill /home/akbar/Pictures/desktop_wallpapers/dark/housesForHyprland.jpg
# exec_always --no-startup-id feh --bg-fill /home/akbar/Pictures/desktop_wallpapers/light/nissan_gtr-34.png

exec_always --no-startup-id ~/.config/polybar/polybar_launcher.sh
exec_always --no-startup-id picom --config ~/.config/picom/picom.conf
exec_always --no-startup-id pgrep -x gammastep >/dev/null || gammastep
exec_always --no-startup-id pgrep -x dunst >/dev/null || dunst
exec_always --no-startup-id pgrep -f "[/]usr/bin/autotiling" >/dev/null || autotiling
exec_always --no-startup-id amixer -c0 sset 'Auto-Mute Mode' Enabled
# OSD watcher (transient dunst popups).
exec_always --no-startup-id python3 ~/.config/i3/osd/lockkeys.py
# Clipboard manager: copyq, event-driven (headless server + polybar refresh).
exec_always --no-startup-id ~/.config/i3/clipboard/copyq-setup.sh

# Screen lock
exec_always --no-startup-id pgrep -x xss-lock >/dev/null || xss-lock --transfer-sleep-lock -- ~/.config/i3/lock.sh
exec_always --no-startup-id xset s 300 300
exec_always --no-startup-id xset dpms 600 600 600

### Startup apps — `exec` (NOT exec_always): launched once per login, so they
### are not re-spawned/duplicated on every $mod+Shift+r restart.
exec --no-startup-id strawberry
exec --no-startup-id kitty -e tmux new-session -A -s akbar
