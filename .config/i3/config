### variables
# logo key. Use Mod1 for Alt.
set $mod Mod4

# workspace names
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

### Movement
# change focus (Vim-style)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+r mode "resize"
mode "resize" {
        bindsym l resize shrink width 10 px or 10 ppt
        bindsym h resize grow width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym j resize shrink height 10 px or 10 ppt
        # Back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+equal scratchpad show

### Window manipulation
# kill focused window
bindsym $mod+q kill

# toggle full screen mode
bindsym $mod+f fullscreen toggle

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# toggle focus between floating window and tiling window
bindsym $mod+Tab focus mode_toggle

# drag windows by holding $mod and clicking with mouse anywhere on the window
floating_modifier $mod

# move to urgent window
focus_on_window_activation focus

# always floating windows
for_window [class="mpv"] floating enable
for_window [class="loupe"] floating enable
for_window [class="pavucontrol"] floating enable
for_window [class="gnome-calculator"] floating enable
for_window [class="org.gnome.Nautilus"] floating enable
for_window [class="Netsoft-com.netsoft.hubstaff"] floating enable
for_window [class="org.gnome.FileRoller"] floating enable

### Key bindings
# open terminal
bindsym $mod+Return exec kitty

# default browser
bindsym $mod+b exec google-chrome

# file manager
bindsym $mod+e exec nautilus

# application launcher (rofi)
bindsym $mod+space exec --no-startup-id rofi -show drun
# web search / URL opener (rofi -> default browser via xdg-open)
bindsym $mod+s exec --no-startup-id rofi -show web -modi "web:~/.config/rofi/websearch.sh" -p search
# run a command in kitty (--hold keeps the window open after it exits, so quick
# commands like `ls`/`npm i` don't flash-and-close; bash -c allows pipes etc.)
bindsym $mod+t exec --no-startup-id rofi -show run -run-command 'kitty --hold -e bash -c "{cmd}"'
# application switcher (rofi)
bindsym Mod1+Tab exec --no-startup-id ~/.config/rofi/window-switcher.sh
# clipboard history (cliphist + rofi)
bindsym $mod+v exec --no-startup-id ~/.config/i3/clipboard/clip-menu.sh
# emoji picker (bemoji + rofi)
bindsym $mod+Shift+e exec --no-startup-id ~/.config/i3/emoji.sh
# power menu (round applet, rofi) — also on the polybar power icon
bindsym Control+Mod1+Delete exec --no-startup-id ~/.config/rofi/powermenu/powermenu.sh

#   Print        -> full screen (save + copy + notify/open)
bindsym   Print     exec --no-startup-id ~/.config/i3/screenshot.sh screen
#   $mod+[  -> select area (save + copy + notify/open)
bindcode  $mod+34   exec --no-startup-id ~/.config/i3/screenshot.sh area
#   $mod+]  -> select area (copy to clipboard only + notify)
bindcode  $mod+35   exec --no-startup-id ~/.config/i3/screenshot.sh copy

### Control
# Volume — adjust + show a dunst OSD progress bar (SwayOSD replacement)
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/i3/osd/volume.sh up
bindsym XF86AudioLowerVolume exec --no-startup-id ~/.config/i3/osd/volume.sh down
bindsym XF86AudioMute        exec --no-startup-id ~/.config/i3/osd/volume.sh mute

# Brightness — adjust + show a dunst OSD progress bar
bindsym XF86MonBrightnessUp   exec --no-startup-id ~/.config/i3/osd/brightness.sh up
bindsym XF86MonBrightnessDown exec --no-startup-id ~/.config/i3/osd/brightness.sh down

# media (playerctl)
bindsym XF86AudioPlay  exec --no-startup-id playerctl play-pause
bindsym XF86AudioPause exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext  exec --no-startup-id playerctl next
bindsym XF86AudioPrev  exec --no-startup-id playerctl previous
bindsym XF86AudioStop  exec --no-startup-id playerctl stop

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

### UI
# window borders
default_border pixel 3
default_floating_border pixel 3
for_window [class=".*"] border pixel 3

# gaps
gaps inner 7
gaps outer 0

# colors
client.focused          #df8e1d #df8e1d #ffffff #df8e1d #df8e1d
client.unfocused        #444444 #444444 #888888 #444444 #444444
client.focused_inactive #333333 #333333 #aaaaaa #333333 #333333

# font
font pango:Ubuntu 11

### Startup applications
# x11 environment
exec_always --no-startup-id systemctl --user unset-environment SWAYSOCK WAYLAND_DISPLAY
exec_always --no-startup-id dbus-update-activation-environment --systemd XDG_SESSION_TYPE=x11 XDG_CURRENT_DESKTOP=i3 DISPLAY XAUTHORITY
